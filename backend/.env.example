# Competition mode
# Keep 1 for the competition/demo build. Set to 0 only when you explicitly need external LLM calls.
SOILSIGHT_COMPETITION_MODE=1

# LLM chat / planning (only used when SOILSIGHT_COMPETITION_MODE=0)
LLM_API_KEY=your_api_key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.4

# Knowledge base retrieval
# KNOWLEDGE_BASE_ROOT=D:/SoilSight/knowledge_base
KNOWLEDGE_BASE_CATEGORIES=core

# Embedding retrieval (only used when SOILSIGHT_COMPETITION_MODE=0)
# Leave EMBEDDING_MODEL empty to disable embeddings and use keyword-only retrieval.
# If EMBEDDING_API_KEY is empty, it falls back to LLM_API_KEY.
# If EMBEDDING_BASE_URL is empty, it falls back to LLM_BASE_URL.
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_TIMEOUT_SECONDS=20

# Example: API embedding service
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# Example: local OpenAI-compatible embedding service
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
# EMBEDDING_API_KEY=local_dummy_key
