# =========================
# SoilSight root .gitignore
# =========================

# --- OS / Editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
.claude/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# --- Environments / secrets ---
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# --- Logs ---
*.log
logs/

# --- Node / Frontend ---
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Build artifacts ---
dist/
build/
tmp/
temp/
share/

# --- Runtime-generated local state ---
data/staging/ai_plan_sessions*.json
frontend/public/overlays/_cotton_tmp/
cotton.json
sugarbeet.json

# --- Internal / dev docs not published ---
AGENTS.md
Git规范.md
docs/
data/10003274/
data/patches/
data/README.md
data/**/*.pdf
data/**/*.xlsx
Makefile
configs/
backend/README.md
frontend/README.md
knowledge_base/
backend/tests/
frontend/tests/
frontend/src/*.test.*
frontend/src/**/*.test.*

# --- Data (large/generated) ---
data/raw/
data/features/
data/xinjiang-NDVI/
data/xinjiang-MCD12Q1/
data/scidb_crop_harvest_maps_v1.0/
data/staging/*
data/staging/archive_*/

# SoilGrids temp tiles and runtime logs
data/**/_tiles_tmp/
data/**/*.log

# Large binary data formats
data/**/*.tif
data/**/*.tiff
data/**/*.nc
data/**/*.hdf
data/**/*.h5
data/**/*.zip
data/**/*.rar
data/**/*.7z
data/**/*.grib
data/**/*.vrt
data/**/*.geojson

